---
/**
 * Uses Page - Tools & Engineering Stack
 * Renders the single MDX file from the uses collection as a content page.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import { getCollection, render } from 'astro:content';
import { pagesConfig } from '../pages.config';

const allUses = await getCollection('uses');
const usesEntry = allUses[0]; // single file

let Content: any = null;
if (usesEntry) {
  const rendered = await render(usesEntry);
  Content = rendered.Content;
}
---

<BaseLayout>
  <SEO 
    slot="head"
    title={pagesConfig.uses.title}
    description={pagesConfig.uses.description}
    type="website"
  />

  <main class="page-container">
    <header class="page-header">
      <h1 class="page-title">{pagesConfig.uses.heading}</h1>
      <p class="page-intro">
        {pagesConfig.uses.intro}
      </p>
    </header>

    {Content ? (
      <div class="uses-content prose">
        <Content />
      </div>
    ) : (
      <p class="empty-state">No uses documented yet.</p>
    )}
  </main>

  <style>
    .page-container {
      max-width: 720px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
    }

    .page-header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--color-border);
    }

    .page-title {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      margin-bottom: 1rem;
      color: var(--color-text);
    }

    .page-intro {
      font-size: 1.1rem;
      color: var(--color-text-secondary);
      line-height: 1.7;
      margin: 0;
    }

    .uses-content {
      line-height: 1.8;
    }

    .uses-content :global(h2) {
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
      color: var(--color-text);
    }

    .uses-content :global(h3) {
      font-size: 1.1rem;
      font-weight: 600;
      margin-top: 1.5rem;
      margin-bottom: 0.4rem;
      color: var(--color-text);
    }

    .uses-content :global(p) {
      color: var(--color-text-secondary);
      margin-bottom: 0.75rem;
    }

    .uses-content :global(strong) {
      color: var(--color-text);
    }

    .empty-state {
      color: var(--color-text-secondary);
      font-style: italic;
    }
  </style>
</BaseLayout>
